import cv2
import numpy as np

img = cv2.imread(r"C:\Users\tgjai\OneDrive\Pictures\Screenshots\Sample.jpeg")

hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)

lower = np.array([0, 50, 50])
upper = np.array([180, 255, 255])

mask = cv2.inRange(hsv, lower, upper)

foreground_removed = cv2.bitwise_and(img, img, mask=cv2.bitwise_not(mask))

cv2.imshow("Original Image", img)
cv2.imshow("Foreground Subtracted Image", foreground_removed)

cv2.waitKey(0)
cv2.destroyAllWindows()
