import cv2

eye_cascade = cv2.CascadeClassifier(r"C:\Users\tgjai\Downloads\haarcascade_eye.xml")

img = cv2.imread(r"C:\Users\tgjai\OneDrive\Pictures\Screenshots\Sample.jpeg")

gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

eyes = eye_cascade.detectMultiScale(gray, 1.3, 5)

for (x,y,w,h) in eyes:
    cv2.rectangle(img,(x,y),(x+w,y+h),(255,0,0),2)

cv2.imshow("Eye Detection", img)

cv2.waitKey(0)
cv2.destroyAllWindows()
