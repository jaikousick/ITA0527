import cv2

cap = cv2.VideoCapture(r"C:\Users\tgjai\Videos\Video 1.mp4")

frames = []

while True:
    ret, frame = cap.read()
    if not ret:
        break
    frames.append(frame)

cap.release()

frames.reverse()

for frame in frames:
    cv2.imshow("Reverse Slow Motion Video", frame)
    
    if cv2.waitKey(100) & 0xFF == ord('q'):
        break

cv2.destroyAllWindows()
